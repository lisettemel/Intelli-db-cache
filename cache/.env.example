# ============================================================
# intelli-dns — Variables de Entorno (cache/)
# Copia este archivo como .env y rellena con tus valores reales.
# NUNCA subas este archivo a git con valores reales.
# ============================================================

# IP privada de la VM (o 127.0.0.1 para desarrollo local)
DB_BIND_IP=10.0.0.5
REDIS_BIND_IP=10.0.0.5

# Credenciales de PostgreSQL
DB_NAME=intellidns
DB_USER=intellidns_admin
DB_PASSWORD=tuPasswordSegura

# Credenciales de Redis
REDIS_HOST=10.0.0.5
REDIS_PORT=6379
REDIS_PASSWORD=tuPasswordSeguraDeRedis
